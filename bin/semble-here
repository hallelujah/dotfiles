#!/bin/sh
# semble-here — search the current git work-tree (or cwd) with semble.
#
# Usage:
#   semble-here "<query>" [--top-k N] [extra semble flags...]
#   semble-here --related <file> <line> [--top-k N]
#
# Thin wrapper so you don't have to type the trailing "." every time.

set -eu

if ! command -v semble >/dev/null 2>&1; then
  echo "semble: not installed. Run rcup, or: uv tool install 'semble[mcp]'" >&2
  exit 127
fi

root=$(git rev-parse --show-toplevel 2>/dev/null) || root=$PWD

case "${1-}" in
  ""|-h|--help)
    sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
    ;;
  --related)
    shift
    file=${1:?missing <file>}
    line=${2:?missing <line>}
    shift 2
    exec semble find-related "$file" "$line" "$root" "$@"
    ;;
  *)
    query=$1
    shift
    exec semble search "$query" "$root" "$@"
    ;;
esac
