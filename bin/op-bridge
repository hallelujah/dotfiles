#!/usr/bin/env zsh
# op-bridge: Unified 1Password CLI + SSH agent bridge
# Linked by rcup to ~/.bin/op-bridge
# Platforms: WSL (→ Windows), macOS, Fedora, NixOS

IS_WSL=false
IS_MACOS=false

if grep -qi microsoft /proc/version 2>/dev/null; then
  IS_WSL=true
elif [ "$(uname -s)" = "Darwin" ]; then
  IS_MACOS=true
fi

# ---------------------------------------------------------------------------
# 1) op wrapper
# ---------------------------------------------------------------------------
if $IS_WSL; then
  if ! command -v op.exe >/dev/null 2>&1; then
    echo >&2 "op.exe not found. Install 1Password CLI on Windows."
    return 1 2>/dev/null || exit 1
  fi
  op() { op.exe "$@" | tr -d '\r'; }
else
  if ! command -v op >/dev/null 2>&1; then
    echo >&2 "op not found. Install 1Password CLI for your platform."
    return 1 2>/dev/null || exit 1
  fi
  op() { command op "$@"; }
fi

# ---------------------------------------------------------------------------
# 2) SSH agent
# ---------------------------------------------------------------------------
setup_ssh_agent_wsl() {
  local pipe='//./pipe/openssh-ssh-agent'
  local sock="${HOME}/.1password/agent.sock"

  if ! command -v socat >/dev/null 2>&1; then
    echo >&2 "socat not found."
    return 1
  fi

  local relay
  relay="$(command -v npiperelay.exe 2>/dev/null || true)"
  if [ -z "$relay" ]; then
    local win_home
    win_home="$(wslpath "$(cmd.exe /C 'echo %USERPROFILE%' 2>/dev/null | tr -d '\r')")"
    relay="${win_home}/go/bin/npiperelay.exe"
    [ -x "$relay" ] || {
      echo >&2 "npiperelay.exe not found."
      return 1
    }
  fi

  if [ -S "$sock" ] && SSH_AUTH_SOCK="$sock" ssh-add -l >/dev/null 2>&1; then
    export SSH_AUTH_SOCK="$sock"
    return 0
  fi

  rm -f "$sock"
  mkdir -p "$(dirname "$sock")"
  (setsid socat \
    UNIX-LISTEN:"${sock}",fork,unlink-early \
    EXEC:"${relay} -ei -s ${pipe}",nofork &) >/dev/null 2>&1

  for _ in 1 2 3 4 5; do
    [ -S "$sock" ] && break
    sleep 0.2
  done
  export SSH_AUTH_SOCK="$sock"
}

setup_ssh_agent_native() {
  local op_sock
  if $IS_MACOS; then
    op_sock="${HOME}/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  else
    op_sock="${HOME}/.1password/agent.sock"
  fi

  if [ -S "$op_sock" ]; then
    export SSH_AUTH_SOCK="$op_sock"
  else
    echo >&2 "1Password SSH agent socket not found at: $op_sock"
    return 1
  fi
}

if $IS_WSL; then
  setup_ssh_agent_wsl
else
  setup_ssh_agent_native
fi

# ---------------------------------------------------------------------------
# 3) GPG key import from 1Password — run once on a new machine
#    To store your key: gpg --export-secret-keys --armor KEY_ID \
#      | op document create - --title "GPG Private Key"
# ---------------------------------------------------------------------------
op_gpg_import() {
  local item_title="${1:-GPG Private Key}"
  local account key_data

  _choose_op_account() {
    local accounts shorthands count choice
    accounts=$(op account list --format=json)
    shorthands=("${(@f)$(echo "$accounts" | jq -r '.[].url')}")
    count=${#shorthands[@]}

    if [[ "$count" -eq 1 ]]; then
      _OP_ACCOUNT="${shorthands[1]}"
      return
    fi

    echo "Select 1Password account:" >/dev/tty
    for i in $(seq 1 $count); do
      echo "  $i) ${shorthands[$i]}" >/dev/tty
    done
    read -r "choice?Enter number: " </dev/tty
    _OP_ACCOUNT="${shorthands[$choice]}"
  }

  _OP_ACCOUNT=""
  _choose_op_account
  account="$_OP_ACCOUNT"
  unset _OP_ACCOUNT

  if [[ -z "$account" ]]; then
    echo >&2 "No 1Password account selected."
    return 1
  fi

  echo "Fetching '${item_title}' from account '${account}'..." >/dev/tty
  key_data="$(op --account "$account" document get "$item_title" 2>/dev/null | tr -d '\r')"

  if [[ -z "$key_data" ]]; then
    cat >&2 <<EOF
Could not fetch '${item_title}' from 1Password (account: $account).
Store your key first:
  gpg --export-secret-keys --armor KEY_ID \\
    | op document create - --title "GPG Private Key"
EOF
    return 1
  fi

  echo "$key_data" | gpg --import &&
    echo "GPG key imported. Open a new shell to activate signing."
}
# ---------------------------------------------------------------------------
# 4) GPG agent via keychain — once per login session
# ---------------------------------------------------------------------------
setup_gpg_keychain() {
  if ! command -v keychain >/dev/null 2>&1; then
    return 0
  fi

  local gpg_keys
  gpg_keys="$(gpg --list-secret-keys --with-colons 2>/dev/null |
    awk -F: '/^sec/{print $5}' | tr '\n' ' ')"

  [ -z "$gpg_keys" ] && return 0

  # Save 1Password SSH socket before keychain eval
  local saved="${SSH_AUTH_SOCK:-}"

  # --agents deprecated in 2.9.8; omit it — keychain detects gpg keys by fingerprint
  # shellcheck disable=SC2086
  eval "$(keychain --eval --quiet $gpg_keys --ssh-allow-gpg)"

  # Restore 1Password SSH socket unconditionally
  [ -n "$saved" ] && export SSH_AUTH_SOCK="$saved"
}

setup_gpg_keychain
