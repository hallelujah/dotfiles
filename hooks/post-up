#!/bin/sh

touch "$HOME"/.psqlrc.local

# Install/update LazyVim plugins
if [ -f "$HOME/.config/nvim/init.lua" ]; then
  nvim --headless "+Lazy! sync" +qa
fi

# Install/upgrade semble (code-search MCP server) idempotently.
# Used by the mcphub entry "semble" via `uvx --from semble[mcp] semble`.
if command -v uv >/dev/null 2>&1; then
  uv tool install --upgrade 'semble[mcp]' >/dev/null

  # Pre-warm the potion-code-16M embedding model so first MCP call is fast.
  # Indexes this repo (tiny, sub-second) which downloads the model into uv cache.
  if command -v semble >/dev/null 2>&1 && [ -d "$HOME/dotfiles" ]; then
    semble search 'init' "$HOME/dotfiles" --top-k 1 >/dev/null 2>&1 || true
  fi
fi

# Restart mcp-hub when config/mcphub/servers.json changed since last rcup.
servers="$HOME/.config/mcphub/servers.json"
marker="$HOME/.cache/dotfiles/mcphub-servers.mtime"
if [ -e "$servers" ]; then
  mkdir -p "$(dirname "$marker")"
  current=$(stat -c %Y "$servers" 2>/dev/null || stat -f %m "$servers" 2>/dev/null || echo 0)
  previous=$(cat "$marker" 2>/dev/null || echo 0)
  if [ "$current" != "$previous" ]; then
    if command -v systemctl >/dev/null 2>&1 && \
       systemctl --user is-active mcp-hub >/dev/null 2>&1; then
      systemctl --user restart mcp-hub
    elif command -v launchctl >/dev/null 2>&1 && \
         launchctl print "gui/$(id -u)/com.user.mcp-hub" >/dev/null 2>&1; then
      launchctl kickstart -k "gui/$(id -u)/com.user.mcp-hub"
    fi
    echo "$current" > "$marker"
  fi
fi

reset -Q

if [ -f "$HOME/.git_template/HEAD" ] && \
  [ "$(cat "$HOME/.git_template/HEAD")" = "ref: refs/heads/main" ]; then
  echo "Removing ~/.git_template/HEAD in favor of defaultBranch" >&2
  rm -f ~/.git_template/HEAD
fi

# detect old OS X broken /etc/zshenv and suggest rename
if grep -qw path_helper /etc/zshenv 2>/dev/null; then
  dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)

  cat <<MSG >&2
Warning: \`/etc/zshenv' configuration file on your system may cause unexpected
PATH changes on subsequent invocations of the zsh shell. The solution is to
rename the file to \`zprofile':
  sudo mv /etc/{zshenv,zprofile}

(called from ${dir}/post-up:${LINENO})

MSG
fi
